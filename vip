-- Fly loop
RunService.RenderStepped:Connect(function()
    if flyEnabled and flyBV and flyBG then
        local root = getRootPart()
        if not root then return end
        flyBG.CFrame = Camera.CFrame
        
        local dir = Vector3.new(0, 0, 0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
        
        flyBV.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.new(0, 0, 0)
    end
end)

-- Main game loop
RunService.Heartbeat:Connect(function()
    -- Speed Boost (3 methods)
    if speedEnabled then
        local root = getRootPart()
        local humanoid = getHumanoid()
        if root and humanoid then
            local method = Options.SpeedMethod and Options.SpeedMethod.Value or "WalkSpeed"
            local moving = humanoid.MoveDirection.Magnitude > 0
            
            if method == "WalkSpeed" then
                humanoid.WalkSpeed = walkSpeed
            elseif method == "CFrame" and moving then
                root.CFrame = root.CFrame + (humanoid.MoveDirection * (walkSpeed / 60))
            elseif method == "Velocity" and moving then
                root.Velocity = Vector3.new(
                    humanoid.MoveDirection.X * walkSpeed,
                    root.Velocity.Y,
                    humanoid.MoveDirection.Z * walkSpeed
                )
            end
        end
    end
    
    -- Noclip
    if noclipEnabled then
        local char = getCharacter()
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end
    
    -- Force Time
    if forceTimeEnabled then
        Lighting.ClockTime = forceTimeValue
    end
    
    -- Auto Climb speed update
    if autoClimbEnabled then
        local root = getRootPart()
        if root then
            local bf = root:FindFirstChild("AutoClimbForce")
            if bf then bf.Velocity = Vector3.new(0, autoClimbSpeed, 0) end
        end
    end
    
    -- Anti-Wind
    if antiWindEnabled then
        local root = getRootPart()
        if root then
            for _, obj in pairs(root:GetChildren()) do
                if (obj:IsA("BodyForce") or obj:IsA("VectorForce") or obj:IsA("LinearVelocity")) and obj.Name ~= "AutoClimbForce" then
                    obj:Destroy()
                end
            end
            if not flyEnabled then
                local vel = root.Velocity
                if math.abs(vel.X) > 15 or math.abs(vel.Z) > 15 then
                    root.Velocity = Vector3.new(0, vel.Y, 0)
                end
            end
        end
    end
    
    -- Freeze
    if freezeEnabled and freezePos then
        local root = getRootPart()
        if root then
            root.CFrame = freezePos
            root.Velocity = Vector3.new(0, 0, 0)
        end
    end
    
    -- ESP
    if espEnabled then
        for _, player in pairs(Players:GetPlayers()) do
            if player ~= LocalPlayer and player.Character then
                -- Remove ESP from teammates
                if isSameTeam(player) then
                    local char = player.Character
                    local hl = char:FindFirstChild("PlayerESP")
                    if hl then hl:Destroy() end
                    local head = char:FindFirstChild("Head")
                    if head then
                        local bb = head:FindFirstChild("ESPBillboard")
                        if bb then bb:Destroy() end
                    end
                end
                if isSameTeam(player) then continue end
                local char = player.Character
                local head = char:FindFirstChild("Head")
                local root = char:FindFirstChild("HumanoidRootPart")
                local myRoot = getRootPart()
                
                -- No chams (highlight removed)
                
                -- Name + Distance billboard
                if head and not head:FindFirstChild("ESPBillboard") then
                    local bb = Instance.new("BillboardGui")
                    bb.Name = "ESPBillboard"
                    bb.Size = UDim2.new(0, 200, 0, 40)
                    bb.StudsOffset = Vector3.new(0, 3, 0)
                    bb.AlwaysOnTop = true
                    bb.Parent = head
                    
                    local nameLabel = Instance.new("TextLabel")
                    nameLabel.Name = "NameLabel"
                    nameLabel.Size = UDim2.new(1, 0, 0.5, 0)
                    nameLabel.BackgroundTransparency = 1
                    nameLabel.TextColor3 = Color3.fromRGB(255, 255, 255)
                    nameLabel.TextStrokeTransparency = 0.5
                    nameLabel.TextScaled = true
                    nameLabel.Font = Enum.Font.GothamBold
                    nameLabel.Text = player.Name
                    nameLabel.Parent = bb
                    
                    local distLabel = Instance.new("TextLabel")
                    distLabel.Name = "DistLabel"
                    distLabel.Size = UDim2.new(1, 0, 0.5, 0)
                    distLabel.Position = UDim2.new(0, 0, 0.5, 0)
                    distLabel.BackgroundTransparency = 1
                    distLabel.TextColor3 = Color3.fromRGB(200, 200, 200)
                    distLabel.TextStrokeTransparency = 0.5
                    distLabel.TextScaled = true
                    distLabel.Font = Enum.Font.Gotham
                    distLabel.Text = "0m"
                    distLabel.Parent = bb
                end
                
                -- Update distance
                if head and head:FindFirstChild("ESPBillboard") and root and myRoot then
                    local dist = math.floor((myRoot.Position - root.Position).Magnitude)
                    head.ESPBillboard.DistLabel.Text = tostring(dist) .. "m"
                end
            end
        end
    end
    
    if entityEspEnabled then
        for _, model in pairs(Workspace:GetDescendants()) do
            if model:IsA("Model") and model:FindFirstChildOfClass("Humanoid") and not model:FindFirstChild("EntityESP") then
                local isPlayer = false
                for _, p in pairs(Players:GetPlayers()) do
                    if p.Character == model then isPlayer = true; break end
                end
                if not isPlayer then
                    local hl = Instance.new("Highlight")
                    hl.Name = "EntityESP"
                    hl.FillColor = Color3.fromRGB(255, 0, 0)
                    hl.OutlineColor = Color3.fromRGB(255, 50, 50)
                    hl.FillTransparency = 0.5
                    hl.Parent = model
                end
            end
        end
    end
    
    -- Anti-Jumpscare
    if Toggles.AntiJumpscare and Toggles.AntiJumpscare.Value then
        pcall(function()
            for _, sound in pairs(Workspace:GetDescendants()) do
                if sound:IsA("Sound") and sound.Playing and (sound.Volume > 1.5 or sound.PlaybackSpeed > 1.5) then
                    sound.Volume = 0
                end
            end
        end)
    end
end)

