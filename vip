WPGroup:AddButton("Teleport to Waypoint", function()
    local selected = Options.WPSelect.Value
    for i, name in ipairs(waypointNames) do
        if name == selected then
            local root = getRootPart()
            if root then
                root.CFrame = savedPositions[i] + Vector3.new(0, 5, 0)
                Library:Notify("TP to: " .. name, 3)
            end
            break
        end
    end
end)

WPGroup:AddButton("Delete Selected", function()
    local selected = Options.WPSelect.Value
    for i, name in ipairs(waypointNames) do
        if name == selected then
            table.remove(savedPositions, i)
            table.remove(waypointNames, i)
            Options.WPSelect:SetValues(waypointNames)
            saveWP()
            Library:Notify("Deleted: " .. name, 3)
            break
        end
    end
end)

WPGroup:AddButton("Clear All", function()
    savedPositions = {}
    waypointNames = {}
    Options.WPSelect:SetValues({})
    saveWP()
    Library:Notify("All waypoints cleared", 3)
end)

