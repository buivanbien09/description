-- Reach: Extend weapon hitbox
RunService.Heartbeat:Connect(function()
    if not (Toggles.Reach and Toggles.Reach.Value) then return end
    pcall(function()
        local char = getCharacter()
        if not char then return end
        
        -- Find weapon
        local tool = char:FindFirstChildOfClass("Tool")
        if not tool then
            for _, obj in pairs(char:GetChildren()) do
                if obj:IsA("Model") and obj.Name:find("Equipped") then
                    tool = obj; break
                end
            end
        end
        if not tool then return end
        
        -- Extend all parts in weapon
        for _, part in pairs(tool:GetDescendants()) do
            if part:IsA("BasePart") then
                part.Size = Vector3.new(math.max(part.Size.X, 15), math.max(part.Size.Y, 15), math.max(part.Size.Z, 15))
                part.Transparency = 1
                part.CanCollide = false
            end
        end
    end)
end)

-- Desync: Offset real position from visual
local desyncOffset = 7
RunService.Heartbeat:Connect(function()
    if not (Toggles.Desync and Toggles.Desync.Value) then return end
    pcall(function()
        local root = getRootPart()
        if not root then return end
        
        -- Rapidly shift velocity to desync server position
        local offset = Vector3.new(
            math.random(-desyncOffset, desyncOffset),
            0,
            math.random(-desyncOffset, desyncOffset)
        )
        root.Velocity = root.Velocity + offset * 5
        task.wait()
        root.Velocity = root.Velocity - offset * 5
    end)
end)

-- Speed Dodge: Burst speed when shooting
RunService.Heartbeat:Connect(function()
    if not (Toggles.SpeedDodge and Toggles.SpeedDodge.Value) then return end
    pcall(function()
        local root = getRootPart()
        local humanoid = getHumanoid()
        if not root or not humanoid then return end
        
        -- When mouse is held (shooting), burst sideways
        if UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1) then
            local rightDir = Camera.CFrame.RightVector
            local dodgeDir = rightDir * (math.random() > 0.5 and 1 or -1)
            root.Velocity = root.Velocity + dodgeDir * 30
        end
    end)
end)

