    Finished = false,
    Text = "Waypoint Name",
    Placeholder = "Enter name..."
})

WPGroup:AddButton("Save Position", function()
    local root = getRootPart()
    if root then
        local name = Options.WPName.Value
        if name == "" then name = "WP #" .. (#savedPositions + 1) end
        table.insert(savedPositions, root.CFrame)
        table.insert(waypointNames, name)
        Options.WPSelect:SetValues(waypointNames)
        saveWP()
        Library:Notify("Saved: " .. name, 3)
    end
end)

WPGroup:AddDropdown("WPSelect", {
