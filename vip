-- Waypoints
local WAYPOINT_FILE = "UniversalHub_WP_" .. game.PlaceId .. ".json"
local savedPositions = {}
local waypointNames = {}

pcall(function()
    if isfile(WAYPOINT_FILE) then
        local data = HttpService:JSONDecode(readfile(WAYPOINT_FILE))
        for _, wp in ipairs(data) do
            table.insert(waypointNames, wp.name)
            table.insert(savedPositions, CFrame.new(wp.x, wp.y, wp.z))
        end
    end
end)

local function saveWP()
    pcall(function()
        local data = {}
        for i, name in ipairs(waypointNames) do
            local pos = savedPositions[i].Position
            table.insert(data, {name = name, x = pos.X, y = pos.Y, z = pos.Z})
        end
        writefile(WAYPOINT_FILE, HttpService:JSONEncode(data))
    end)
end

WPGroup:AddInput("WPName", {
