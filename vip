-- Team Check helper (Multi-mode)
local function isSameTeam(player)
    if not (Toggles.TeamCheck and Toggles.TeamCheck.Value) then return false end

    local myChar = LocalPlayer.Character
    local theirChar = player.Character
    if not myChar or not theirChar then return false end

    local mode = Options.TeamCheckMode and Options.TeamCheckMode.Value or "Auto (Thử Tất Cả)"

    -- [1] Roblox Teams
    local function checkRobloxTeam()
        if LocalPlayer.Team and player.Team then
            return LocalPlayer.Team == player.Team
        end
        return false
    end

    -- [2] FactionType Attribute trên character
    local function checkFactionType()
        local a = myChar:GetAttribute("FactionType")
        local b = theirChar:GetAttribute("FactionType")
        if a ~= nil and b ~= nil then return a == b end
        return false
    end

    -- [3] Attribute "Team" trên character hoặc player object
    local function checkTeamAttribute()
        local a = myChar:GetAttribute("Team") or LocalPlayer:GetAttribute("Team")
        local b = theirChar:GetAttribute("Team") or player:GetAttribute("Team")
        if a ~= nil and b ~= nil then return a == b end
        return false
    end

    -- [4] IntValue tên "Team" trong character hoặc player
    local function checkIntValue()
        local function getInt(char, plr)
            local v = char:FindFirstChild("Team") or plr:FindFirstChild("Team")
            if v and v:IsA("IntValue") then return v.Value end
            return nil
        end
        local a = getInt(myChar, LocalPlayer)
        local b = getInt(theirChar, player)
        if a ~= nil and b ~= nil then return a == b end
        return false
    end

    -- [5] StringValue tên "Team" trong character hoặc player
    local function checkStringValue()
        local function getStr(char, plr)
            local v = char:FindFirstChild("Team") or plr:FindFirstChild("Team")
            if v and v:IsA("StringValue") then return v.Value end
            return nil
        end
        local a = getStr(myChar, LocalPlayer)
        local b = getStr(theirChar, player)
        if a ~= nil and b ~= nil and a ~= "" then return a == b end
        return false
    end

    -- [6] TeamColor (màu team Roblox)
    local function checkTeamColor()
        if LocalPlayer.TeamColor and player.TeamColor then
            return LocalPlayer.TeamColor == player.TeamColor
        end
        return false
    end

    -- [7] Tag trên Player object (CollectionService)
    local function checkPlayerTag()
        local CS = game:GetService("CollectionService")
        local myTags  = CS:GetTags(LocalPlayer)
        local theirTags = CS:GetTags(player)
        for _, tag in pairs(myTags) do
            local lower = tag:lower()
            if lower:find("team") or lower:find("faction") or lower:find("side") or lower:find("clan") then
                for _, t2 in pairs(theirTags) do
                    if t2 == tag then return true end
                end
            end
        end
        return false
    end

    -- [8] Tag trên Character model (CollectionService)
    local function checkCharTag()
        local CS = game:GetService("CollectionService")
        local myTags    = CS:GetTags(myChar)
        local theirTags = CS:GetTags(theirChar)
        for _, tag in pairs(myTags) do
            local lower = tag:lower()
            if lower:find("team") or lower:find("faction") or lower:find("side") or lower:find("clan") then
                for _, t2 in pairs(theirTags) do
                    if t2 == tag then return true end
                end
            end
        end
        return false
    end

    -- [9] leaderstats — tìm StringValue/IntValue tên Team/Faction/Side trong leaderstats
    local function checkLeaderstats()
        local keys = {"Team", "Faction", "Side", "Clan", "Guild"}
        local myStats    = LocalPlayer:FindFirstChild("leaderstats")
        local theirStats = player:FindFirstChild("leaderstats")
        if not myStats or not theirStats then return false end
        for _, key in ipairs(keys) do
            local a = myStats:FindFirstChild(key)
            local b = theirStats:FindFirstChild(key)
            if a and b and (a:IsA("StringValue") or a:IsA("IntValue")) then
                if a.Value ~= nil and a.Value ~= "" and a.Value == b.Value then
                    return true
                end
            end
        end
        return false
    end

    -- [10] DisplayName Prefix — match tag trong ngoặc vuông, ví dụ [RED], [BLUE]
    local function checkDisplayPrefix()
        local function getPrefix(name)
            return name:match("^(%[.-%])")
        end
        local myPrefix    = getPrefix(LocalPlayer.DisplayName)
        local theirPrefix = getPrefix(player.DisplayName)
        if myPrefix and theirPrefix and myPrefix ~= "" then
            return myPrefix == theirPrefix
        end
        -- Thử cả Name
        local myPrefixN    = getPrefix(LocalPlayer.Name)
        local theirPrefixN = getPrefix(player.Name)
        if myPrefixN and theirPrefixN and myPrefixN ~= "" then
            return myPrefixN == theirPrefixN
        end
        return false
    end

    -- [11] BodyColor Match — so BrickColor của Torso/UpperTorso
    local function checkBodyColor()
        local function getTorsoColor(char)
            local part = char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
            if part and part:IsA("BasePart") then return part.BrickColor end
            return nil
        end
        local a = getTorsoColor(myChar)
        local b = getTorsoColor(theirChar)
        if a and b then return a == b end
        return false
    end

    -- [12] Humanoid Attribute — tìm attribute Team/Faction/Side/Alliance trên Humanoid
    local function checkHumanoidAttr()
        local myHum    = myChar:FindFirstChildOfClass("Humanoid")
        local theirHum = theirChar:FindFirstChildOfClass("Humanoid")
        if not myHum or not theirHum then return false end
        local keys = {"Team", "Faction", "Side", "Alliance", "Clan"}
        for _, key in ipairs(keys) do
            local a = myHum:GetAttribute(key)
            local b = theirHum:GetAttribute(key)
            if a ~= nil and b ~= nil and a == b then return true end
        end
        return false
    end

    -- [13] PlayerGui Value — tìm StringValue/IntValue tên Team/Faction trong PlayerGui
    local function checkPlayerGuiValue()
        local function getGuiVal(plr)
            local gui = plr:FindFirstChild("PlayerGui")
            if not gui then return nil end
            for _, key in ipairs({"Team", "Faction", "Side"}) do
                local v = gui:FindFirstChild(key, true)
                if v and (v:IsA("StringValue") or v:IsA("IntValue")) then
                    return tostring(v.Value)
                end
            end
            return nil
        end
        local a = getGuiVal(LocalPlayer)
        local b = getGuiVal(player)
        if a and b and a ~= "" then return a == b end
        return false
    end

    -- [14] CurrentDuel Attribute — game 1v1 kiểu Rivals
    -- Cùng CurrentDuel = đang đấu cùng phòng → coi là "cùng phòng" → skip ESP
    -- Khác CurrentDuel hoặc không có = ở phòng khác → hiện ESP
    local function checkCurrentDuel()
        local myDuel    = LocalPlayer:GetAttribute("CurrentDuel")
        local theirDuel = player:GetAttribute("CurrentDuel")
        -- Cả 2 có CurrentDuel và KHÁC nhau = không cùng trận → không skip (return false)
        -- Cả 2 có CurrentDuel và BẰNG nhau = cùng trận → skip (return true)
        -- Nếu 1 trong 2 không có attribute = không xác định được → không skip
        if myDuel ~= nil and theirDuel ~= nil then
            return myDuel == theirDuel
        end
        return false
    end

    -- ── Route theo mode ────────────────────────────────────────────────────────
    if mode == "Roblox Teams" then
        return checkRobloxTeam()
    elseif mode == "FactionType Attribute" then
        return checkFactionType()
    elseif mode == "Team Attribute" then
        return checkTeamAttribute()
    elseif mode == "IntValue (Team)" then
        return checkIntValue()
    elseif mode == "StringValue (Team)" then
        return checkStringValue()
    elseif mode == "TeamColor" then
        return checkTeamColor()
    elseif mode == "Tag (CollectionService)" then
        return checkPlayerTag()
    elseif mode == "Tag (Character)" then
        return checkCharTag()
    elseif mode == "leaderstats" then
        return checkLeaderstats()
    elseif mode == "DisplayName Prefix" then
        return checkDisplayPrefix()
    elseif mode == "BodyColor Match" then
        return checkBodyColor()
    elseif mode == "Humanoid Attribute" then
        return checkHumanoidAttr()
    elseif mode == "PlayerGui Value" then
        return checkPlayerGuiValue()
    elseif mode == "CurrentDuel (Rivals/1v1)" then
        return checkCurrentDuel()
    else
        -- Auto: thử tất cả theo thứ tự, method nào match thì return true
        return checkRobloxTeam()
            or checkFactionType()
            or checkTeamAttribute()
            or checkIntValue()
            or checkStringValue()
            or checkTeamColor()
            or checkPlayerTag()
            or checkCharTag()
            or checkLeaderstats()
            or checkDisplayPrefix()
            or checkBodyColor()
            or checkHumanoidAttr()
            or checkPlayerGuiValue()
        -- CurrentDuel KHÔNG nằm trong Auto vì nó lọc theo phòng, không phải đồng đội
    end
end
-- Ultra Pull System (fast + accurate + auto switch)
local cachedTarget = nil
local lockedDist = 9999

-- Hàm kiểm tra xem mục tiêu có hợp lệ để kéo hay không
local function isValidTarget(player)
    if player == LocalPlayer or not player.Character then return false end
    local root = player.Character:FindFirstChild("HumanoidRootPart")
    local hum = player.Character:FindFirstChildOfClass("Humanoid")
    if not root or not hum or hum.Health <= 0 then return false end
    
    -- Bỏ qua đồng đội
    if isSameTeam(player) then return false end
    -- Bỏ qua khi có ForceField (khiên bất tử lúc hồi sinh)
    if player.Character:FindFirstChildOfClass("ForceField") then return false end
    -- Bỏ qua god mode
    if hum.MaxHealth >= 999999 then return false end
    
    local entityState = player.Character:GetAttribute("EntityState")
    if entityState and entityState ~= 1 then return false end
    
    return true
end

RunService.RenderStepped:Connect(function(dt)
    if not pullEnabled then 
        cachedTarget = nil 
        lockedDist = 9999
        return 
    end
    
    local myRoot = getRootPart()
    if not myRoot then return end
    
    -- Cập nhật tình trạng của mục tiêu hiện tại
    if cachedTarget and not isValidTarget(cachedTarget) then
        cachedTarget = nil
        lockedDist = 9999
    end
    
    -- Tạo độ trễ và "giãn" khoảng cách ảo cho target hiện tại
    -- Mục đích: Nếu player hiện tại chạy xa ra, script sẽ tự động tăng khoảng cách nội bộ lên.
    -- Điều này giúp nhường quyền ưu tiên cho người chơi khác bước vào gần hơn.
    if cachedTarget then
        lockedDist = lockedDist + (25 * dt) -- Tăng dần khoảng cách giả lập
        if lockedDist > pullRadius then
            cachedTarget = nil
            lockedDist = 9999
        end
    end
    
    local bestTarget = cachedTarget
    local bestDist = lockedDist
    
    -- Quét để tìm người chơi gần nhất theo Real Time
    for _, player in pairs(Players:GetPlayers()) do
        if isValidTarget(player) and player ~= cachedTarget then
            local root = player.Character:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (myRoot.Position - root.Position).Magnitude
                -- Nếu phát hiện người nào đó lại gần hơn (nhỏ hơn khoảng cách locked hiện tại)
                if dist <= pullRadius and dist < bestDist then
                    bestDist = dist
                    bestTarget = player
                end
            end
        end
    end
    
    -- Lập tức Switch sang mục tiêu ưu tiên mới nhất
    if bestTarget ~= cachedTarget then
        cachedTarget = bestTarget
        lockedDist = bestDist
    end
    
    -- Bắt đầu pull mục tiêu
    if cachedTarget and cachedTarget.Character then
        local targetRoot = cachedTarget.Character:FindFirstChild("HumanoidRootPart")
        local head = cachedTarget.Character:FindFirstChild("Head")
        if targetRoot then
            local lookDir = Camera.CFrame.LookVector
            local crosshairPos = Camera.CFrame.Position + lookDir * pullDistance
            
            -- Đặt vị trí Root sao cho phần Head nằm ngay tâm ngắm
            local headYOffset = head and (head.Position.Y - targetRoot.Position.Y) or 1.5
            local rootPos = crosshairPos - Vector3.new(0, headYOffset + 0.2, 0)
            
            -- CFrame đè liên tục mỗi frame
            targetRoot.CFrame = CFrame.new(rootPos, Camera.CFrame.Position)
            targetRoot.Velocity = Vector3.zero
            targetRoot.RotVelocity = Vector3.zero
            targetRoot.AssemblyLinearVelocity = Vector3.zero
            targetRoot.AssemblyAngularVelocity = Vector3.zero
        end
    end
end)

