-- Hàm kiểm tra xem mục tiêu (Model) có hợp lệ để kéo hay không
local function isValidTarget(char)
    if not char or char == LocalPlayer.Character then return false end
    
    local root = char:FindFirstChild("HumanoidRootPart")
    local hum = char:FindFirstChildOfClass("Humanoid")
    
    if not root or not hum or hum.Health <= 0 or hum:GetState() == Enum.HumanoidStateType.Dead then 
        return false 
    end
    
    local plr = Players:GetPlayerFromCharacter(char)
    if plr and isSameTeam(plr) then return false end
    
    if char:FindFirstChildOfClass("ForceField") then return false end
    if hum.MaxHealth >= 999999 then return false end
    
    local entityState = char:GetAttribute("EntityState")
    if entityState and entityState ~= 1 then return false end
    
    return true
end

-- Ultra Pull System (Smart FOV Targeting & Auto Switch)
local cachedTargetChar = nil

RunService.RenderStepped:Connect(function()
    if not pullEnabled then 
        cachedTargetChar = nil 
        return 
    end
    
    local myRoot = getRootPart()
    if not myRoot then return end
    
    if cachedTargetChar then
        if not isValidTarget(cachedTargetChar) then
            cachedTargetChar = nil
        else
            local tRoot = cachedTargetChar:FindFirstChild("HumanoidRootPart")
            if tRoot then
                local dist = (myRoot.Position - tRoot.Position).Magnitude
                if dist > pullRadius then
                    cachedTargetChar = nil 
                end
            end
        end
    end
    
    local bestPlayerChar = nil
    local bestPlayerScreenDist = math.huge
    
    local bestBotChar = nil
    local bestBotScreenDist = math.huge
    
    local centerScreen = Vector2.new(Camera.ViewportSize.X / 2, Camera.ViewportSize.Y / 2)
    
    for _, char in ipairs(Workspace:GetChildren()) do
        if char:IsA("Model") and isValidTarget(char) then
            local root = char:FindFirstChild("HumanoidRootPart")
            if root then
                local dist = (myRoot.Position - root.Position).Magnitude
                if dist <= pullRadius then
                    local screenPos, onScreen = Camera:WorldToViewportPoint(root.Position)
                    if onScreen then
                        local screenDist = (Vector2.new(screenPos.X, screenPos.Y) - centerScreen).Magnitude
                        local isRealPlayer = Players:GetPlayerFromCharacter(char) ~= nil
                        
                        if isRealPlayer then
                            if screenDist < bestPlayerScreenDist then
                                bestPlayerScreenDist = screenDist
                                bestPlayerChar = char
                            end
                        else
                            if screenDist < bestBotScreenDist then
                                bestBotScreenDist = screenDist
                                bestBotChar = char
                            end
                        end
                    end
                end
            end
        end
    end
    
    local targetToLock = bestPlayerChar or bestBotChar
    
    if targetToLock then
        cachedTargetChar = targetToLock
    end
    
    if cachedTargetChar then
        local targetRoot = cachedTargetChar:FindFirstChild("HumanoidRootPart")
        local head = cachedTargetChar:FindFirstChild("Head")
        
        if targetRoot then
            local lookDir = Camera.CFrame.LookVector
            local crosshairPos = Camera.CFrame.Position + lookDir * pullDistance
            
            local headYOffset = head and (head.Position.Y - targetRoot.Position.Y) or 1.5
            local rootPos = crosshairPos - Vector3.new(0, headYOffset + 0.2, 0)
            
            targetRoot.CFrame = CFrame.new(rootPos, Camera.CFrame.Position)
            targetRoot.Velocity = Vector3.zero
            targetRoot.RotVelocity = Vector3.zero
            targetRoot.AssemblyLinearVelocity = Vector3.zero
            targetRoot.AssemblyAngularVelocity = Vector3.zero
        end
    end
end)


