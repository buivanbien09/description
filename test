-- Fly loop
RunService.RenderStepped:Connect(function()
    if flyEnabled and flyBV and flyBG then
        local root = getRootPart()
        if not root then return end
        flyBG.CFrame = Camera.CFrame
        
        local dir = Vector3.new(0, 0, 0)
        if UserInputService:IsKeyDown(Enum.KeyCode.W) then dir = dir + Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.S) then dir = dir - Camera.CFrame.LookVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.A) then dir = dir - Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D) then dir = dir + Camera.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space) then dir = dir + Vector3.new(0, 1, 0) end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftShift) then dir = dir - Vector3.new(0, 1, 0) end
        
        flyBV.Velocity = dir.Magnitude > 0 and dir.Unit * flySpeed or Vector3.new(0, 0, 0)
    end
end)

-- Main game loop
RunService.Heartbeat:Connect(function()
    if speedEnabled then
        local root = getRootPart()
        local humanoid = getHumanoid()
        if root and humanoid then
            local method = Options.SpeedMethod and Options.SpeedMethod.Value or "WalkSpeed"
            local moving = humanoid.MoveDirection.Magnitude > 0
            
            if method == "WalkSpeed" then humanoid.WalkSpeed = walkSpeed
            elseif method == "CFrame" and moving then root.CFrame = root.CFrame + (humanoid.MoveDirection * (walkSpeed / 60))
            elseif method == "Velocity" and moving then root.Velocity = Vector3.new(humanoid.MoveDirection.X * walkSpeed, root.Velocity.Y, humanoid.MoveDirection.Z * walkSpeed)
            end
        end
    end
    
    if noclipEnabled then
        local char = getCharacter()
        if char then
            for _, part in pairs(char:GetDescendants()) do
                if part:IsA("BasePart") then part.CanCollide = false end
            end
        end
    end
    
    if freezeEnabled and freezePos then
        local root = getRootPart()
        if root then root.CFrame = freezePos; root.Velocity = Vector3.new(0, 0, 0) end
    end
    
    if Toggles.AntiJumpscare and Toggles.AntiJumpscare.Value then
        pcall(function()
            for _, sound in pairs(Workspace:GetDescendants()) do
                if sound:IsA("Sound") and sound.Playing and (sound.Volume > 1.5 or sound.PlaybackSpeed > 1.5) then sound.Volume = 0 end
            end
        end)
    end
end)

UserInputService.JumpRequest:Connect(function()
    if infJumpEnabled then
        local humanoid = getHumanoid()
        if humanoid then humanoid:ChangeState(Enum.HumanoidStateType.Jumping) end
    end
end)


