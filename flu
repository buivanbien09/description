-- Waypoints System (Persistent - saves to file)
local WaypointSection = Tabs.Teleport:AddSection("Waypoints")

local savedPositions = {}
local waypointNames = {}
local WAYPOINT_FILE = "FluentHub_Waypoints_" .. game.PlaceId .. ".json"

-- Load saved waypoints from file
local function loadWaypoints()
    pcall(function()
        if isfile(WAYPOINT_FILE) then
            local data = game:GetService("HttpService"):JSONDecode(readfile(WAYPOINT_FILE))
            for _, wp in ipairs(data) do
                table.insert(waypointNames, wp.name)
                table.insert(savedPositions, CFrame.new(wp.x, wp.y, wp.z))
            end
        end
    end)
end

-- Save waypoints to file
local function saveWaypoints()
    pcall(function()
        local data = {}
        for i, name in ipairs(waypointNames) do
            local pos = savedPositions[i].Position
            table.insert(data, {name = name, x = pos.X, y = pos.Y, z = pos.Z})
        end
        writefile(WAYPOINT_FILE, game:GetService("HttpService"):JSONEncode(data))
    end)
end

-- Load on start
