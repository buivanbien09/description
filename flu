RunService.Heartbeat:Connect(function(dt)
    if speedEnabled then
        local root = getRootPart()
        local humanoid = getHumanoid()
        if not root or not humanoid then return end
        
        local method = SpeedMethodDropdown.Value or "All"
        local moving = humanoid.MoveDirection.Magnitude > 0
        
        -- Method 1: WalkSpeed (spam every frame)
        if method == "WalkSpeed" or method == "All" then
            humanoid.WalkSpeed = walkSpeed
        end
        
        -- Method 2: CFrame push
        if (method == "CFrame" or method == "All") and moving then
            local boost = humanoid.MoveDirection * (walkSpeed / 60) * dt * 60
            root.CFrame = root.CFrame + boost
        end
        
        -- Method 3: Velocity boost
        if (method == "Velocity" or method == "All") and moving then
            root.Velocity = Vector3.new(
                humanoid.MoveDirection.X * walkSpeed,
                root.Velocity.Y,
                humanoid.MoveDirection.Z * walkSpeed
            )
        end
    end
end)

