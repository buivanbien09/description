-- Shared teleport function
local isTweening = false
local function teleportTo(targetCFrame)
    local root = getRootPart()
    if not root then return end
    local humanoid = getHumanoid()
    
    -- Add Y offset to avoid clipping into terrain
    local finalCFrame = targetCFrame + Vector3.new(0, 5, 0)
    
    if useTween then
        if isTweening then return end
        isTweening = true
        
        local distance = (root.Position - finalCFrame.Position).Magnitude
        local duration = distance / tweenSpeed
        if duration < 0.1 then duration = 0.1 end
        if duration > 30 then duration = 30 end
        
        local tween = TweenService:Create(root, TweenInfo.new(duration, Enum.EasingStyle.Linear), {
            CFrame = finalCFrame
        })
        tween:Play()
        tween.Completed:Connect(function()
            isTweening = false
            -- Reset state after tween
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            root.Velocity = Vector3.new(0, 0, 0)
            root.RotVelocity = Vector3.new(0, 0, 0)
        end)
    else
        root.CFrame = finalCFrame
        -- Reset humanoid state to prevent freezing
        if humanoid then
            humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            humanoid.PlatformStand = false
            humanoid.Sit = false
        end
        root.Velocity = Vector3.new(0, 0, 0)
        root.RotVelocity = Vector3.new(0, 0, 0)
        -- Extra reset after short delay
        task.delay(0.1, function()
            if humanoid then
                humanoid:ChangeState(Enum.HumanoidStateType.GettingUp)
            end
            if root then
                root.Velocity = Vector3.new(0, 0, 0)
            end
        end)
    end
end

