local FullbrightSection = Tabs.Visual:AddSection("Lighting")

local FullbrightToggle = Tabs.Visual:AddToggle("FullbrightToggle", {
    Title = "Fullbright",
    Description = "Remove darkness, fog, weather effects",
    Default = false
})

local originalLighting = {}
local disabledEffects = {}

FullbrightToggle:OnChanged(function(value)
    fullbrightEnabled = value
    local lighting = game:GetService("Lighting")
    
    if value then
        -- Save originals
        originalLighting.Ambient = lighting.Ambient
        originalLighting.Brightness = lighting.Brightness
        originalLighting.FogEnd = lighting.FogEnd
        originalLighting.FogStart = lighting.FogStart
        originalLighting.OutdoorAmbient = lighting.OutdoorAmbient
        originalLighting.GlobalShadows = lighting.GlobalShadows
        originalLighting.ClockTime = lighting.ClockTime
        
        -- Apply fullbright
        lighting.Ambient = Color3.new(1, 1, 1)
        lighting.OutdoorAmbient = Color3.new(1, 1, 1)
        lighting.Brightness = 2
        lighting.FogEnd = 1000000
        lighting.FogStart = 1000000
        lighting.GlobalShadows = false
        lighting.ClockTime = 12
        
        -- Disable all post-processing effects
        for _, effect in pairs(lighting:GetChildren()) do
            if effect:IsA("Atmosphere") then
                disabledEffects[effect] = {Density = effect.Density, Enabled = true}
                effect.Density = 0
            elseif effect:IsA("BloomEffect") then
                disabledEffects[effect] = {Enabled = effect.Enabled}
                effect.Enabled = false
            elseif effect:IsA("BlurEffect") then
                disabledEffects[effect] = {Enabled = effect.Enabled}
                effect.Enabled = false
            elseif effect:IsA("ColorCorrectionEffect") then
                disabledEffects[effect] = {Enabled = effect.Enabled}
                effect.Enabled = false
            elseif effect:IsA("DepthOfFieldEffect") then
                disabledEffects[effect] = {Enabled = effect.Enabled}
                effect.Enabled = false
            elseif effect:IsA("SunRaysEffect") then
                disabledEffects[effect] = {Enabled = effect.Enabled}
                effect.Enabled = false
            end
        end
    else
        -- Restore originals
        lighting.Ambient = originalLighting.Ambient or Color3.new(0, 0, 0)
        lighting.OutdoorAmbient = originalLighting.OutdoorAmbient or Color3.new(128/255, 128/255, 128/255)
        lighting.Brightness = originalLighting.Brightness or 1
        lighting.FogEnd = originalLighting.FogEnd or 10000
        lighting.FogStart = originalLighting.FogStart or 0
        lighting.GlobalShadows = originalLighting.GlobalShadows ~= false
        lighting.ClockTime = originalLighting.ClockTime or 14
        
        -- Restore effects
        for effect, data in pairs(disabledEffects) do
            if effect and effect.Parent then
                if effect:IsA("Atmosphere") then
                    effect.Density = data.Density or 0.3
                else
                    effect.Enabled = data.Enabled ~= false
                end
            end
        end
        disabledEffects = {}
    end
end)

